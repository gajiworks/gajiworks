@using System.ComponentModel.DataAnnotations
<section id="contact" class="section section-anchor contact-section">
    <div class="container contact-grid">
        <div class="contact-copy reveal"><SectionHeading Eyebrow="Start a Project" Title="Tell me what your business needs." Description="Share a few details and I’ll have the context needed to prepare the next steps. This demo form does not send data yet." Centered="false" /><div class="contact-points"><div><span>01</span><p><strong>Clear, direct communication</strong><small>No layers—you speak directly with me.</small></p></div><div><span>02</span><p><strong>Practical recommendations</strong><small>Options matched to your actual goals and budget.</small></p></div><div><span>03</span><p><strong>No-pressure inquiry</strong><small>Start with a conversation, not a commitment.</small></p></div></div></div>
        <div class="contact-card reveal reveal-delay">
            @if (submitted)
            {
                <div class="success-state" role="status"><span>✓</span><h3>Inquiry received</h3><p>Thanks for sharing your project. This is a demo submission, so no message was sent.</p><button class="button button-secondary" type="button" @onclick="Reset">Send another inquiry</button></div>
            }
            else
            {
                <EditForm Model="model" OnValidSubmit="Submit" FormName="project-inquiry"><DataAnnotationsValidator />
                    <div class="form-grid">
                        <div class="field"><label for="name">Name</label><input id="name" @bind="model.Name" @bind:event="oninput" placeholder="Your name" /><ValidationMessage For="() => model.Name" /></div>
                        <div class="field"><label for="business">Business Name</label><input id="business" @bind="model.BusinessName" @bind:event="oninput" placeholder="Business or brand" /></div>
                        <div class="field field-full"><label for="contact-info">Email / Messenger</label><input id="contact-info" @bind="model.Contact" @bind:event="oninput" placeholder="How can I reach you?" /><ValidationMessage For="() => model.Contact" /></div>
                        <div class="field"><label for="project-type">Project Type</label><InputSelect id="project-type" @bind-Value="model.ProjectType"><option value="">Select a project</option><option>Micro / One Page</option><option>Business Website</option><option>Catalog / Showcase</option><option>Custom Web App</option><option>Web Automation &amp; Data Scraping</option></InputSelect><ValidationMessage For="() => model.ProjectType" /></div>
                        <div class="field"><label for="budget">Budget Range</label><InputSelect id="budget" @bind-Value="model.Budget"><option value="">Select a range</option><option>₱8k – ₱25k</option><option>₱25k – ₱60k</option><option>₱60k – ₱120k</option><option>₱120k+</option><option>Not sure yet</option></InputSelect><ValidationMessage For="() => model.Budget" /></div>
                        <div class="field field-full"><label for="message">Message</label><textarea id="message" @bind="model.Message" @bind:event="oninput" placeholder="Tell me about your goals, timeline, or current challenges..."></textarea><ValidationMessage For="() => model.Message" /></div>
                    </div><button class="button button-primary submit-button" type="submit">Send Inquiry <span>→</span></button><p class="form-note">Demo only—this form is not connected to email or an API.</p>
                </EditForm>
            }
        </div>
    </div>
</section>
@code {
    private InquiryModel model = new(); private bool submitted;
    private void Submit() => submitted = true;
    private void Reset() { model = new(); submitted = false; }
    private sealed class InquiryModel
    {
        [Required(ErrorMessage = "Please enter your name.")] public string Name { get; set; } = string.Empty;
        public string BusinessName { get; set; } = string.Empty;
        [Required(ErrorMessage = "Please add an email or Messenger contact.")] public string Contact { get; set; } = string.Empty;
        [Required(ErrorMessage = "Please select a project type.")] public string ProjectType { get; set; } = string.Empty;
        [Required(ErrorMessage = "Please select a budget range.")] public string Budget { get; set; } = string.Empty;
        [Required(ErrorMessage = "Please tell me a little about your project."), MinLength(10, ErrorMessage = "Please add a little more detail.")] public string Message { get; set; } = string.Empty;
    }
}
