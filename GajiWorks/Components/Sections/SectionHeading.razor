<div class="section-heading @(Centered ? "section-heading-centered" : null)">
    <span class="eyebrow">@Eyebrow</span>
    <h2>@Title</h2>
    @if (!string.IsNullOrWhiteSpace(Description)) { <p>@Description</p> }
</div>

@code {
    [Parameter, EditorRequired] public string Eyebrow { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public bool Centered { get; set; } = true;
}
