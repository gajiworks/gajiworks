@implements IDisposable
@inject IJSRuntime JS

@if (Project is not null)
{
    <div class="modal-backdrop" role="presentation" @onclick="Close">
        <section class="project-modal project-modal-detailed" role="dialog" aria-modal="true" aria-labelledby="project-modal-title" @onclick:stopPropagation="true">
            <button class="modal-close" type="button" aria-label="Close project details" @onclick="Close">×</button>

            <div class="modal-gallery">
                <div class="modal-screenshot @Project.AccentClass @(IsImageScreenshot(Project.Screenshots[selectedScreenshot]) ? "has-image" : IsVideoPreview(Project.Screenshots[selectedScreenshot]) ? "has-video" : null)">
                    @if (IsImageScreenshot(Project.Screenshots[selectedScreenshot]))
                    {
                        <img class="modal-screenshot-image" src="@Project.Screenshots[selectedScreenshot]" alt="@Project.Name - @GetScreenshotLabel(Project.Screenshots[selectedScreenshot], selectedScreenshot)" />
                    }
                    else if (IsVideoPreview(Project.Screenshots[selectedScreenshot]))
                    {
                        <video @ref="videoElement" class="modal-video" controls autoplay muted preload="metadata" playsinline poster="@GetVideoPoster()" @onended="HandleVideoEnded">
                            <source src="@Project.Screenshots[selectedScreenshot]" type="video/mp4" />
                            Your browser does not support video playback.
                        </video>
                    }
                    else
                    {
                        <span class="project-window"><i></i><i></i><i></i></span>
                        <div class="screenshot-layout screenshot-layout-@((selectedScreenshot % 3) + 1)">
                            <span class="screenshot-nav"></span>
                            <span class="screenshot-title"></span>
                            <span class="screenshot-copy"></span>
                            <span class="screenshot-panel screenshot-panel-one"></span>
                            <span class="screenshot-panel screenshot-panel-two"></span>
                        </div>
                    }
                    <span class="screenshot-caption">@GetScreenshotLabel(Project.Screenshots[selectedScreenshot], selectedScreenshot)</span>
                </div>

                <div class="screenshot-thumbnails" aria-label="Project media">
                    @for (var index = 0; index < Project.Screenshots.Count; index++)
                    {
                        var screenshotIndex = index;
                        <button class="screenshot-thumbnail @Project.AccentClass @(selectedScreenshot == index ? "active" : null)"
                                type="button"
                                @onclick="() => SelectScreenshot(screenshotIndex)"
                                aria-label="View @GetScreenshotLabel(Project.Screenshots[index], index)"
                                aria-pressed="@((selectedScreenshot == index).ToString().ToLowerInvariant())">
                            @if (IsImageScreenshot(Project.Screenshots[index]))
                            {
                                <img src="@Project.Screenshots[index]" alt="" />
                            }
                            else if (IsVideoPreview(Project.Screenshots[index]))
                            {
                                <span class="video-thumbnail-icon" aria-hidden="true">▶</span>
                            }
                            else
                            {
                                <span>@(index + 1)</span>
                            }
                            <small>@GetScreenshotLabel(Project.Screenshots[index], index)</small>
                        </button>
                    }
                </div>
            </div>

            <div class="modal-copy modal-project-details">
                <span class="project-category">@Project.Category</span>
                <h2 id="project-modal-title">@Project.Name</h2>
                <p>@Project.Description</p>

                <div class="modal-tags" aria-label="Project tags">
                    @foreach (var tag in Project.Tags) { <span>@tag</span> }
                </div>

                <h3>Key features</h3>
                <ul>@foreach (var feature in Project.Features) { <li><span>✓</span>@feature</li> }</ul>

                <div class="project-cost">
                    <small>Estimated similar project cost</small>
                    <strong>@Project.EstimatedCost</strong>
                    <div class="pricing-tags">
                        <span>Starting Estimate</span><span>Negotiable</span><span>Scope-Based</span><span>Discount Available</span>
                    </div>
                    <p>Final pricing may vary depending on scope, timeline, content, features, and support package.</p>
                </div>

                @if (HasLiveLink || HasSourceLink)
                {
                    <div class="hero-actions modal-actions">
                        @if (HasLiveLink) { <a class="button button-primary" href="@Project.LiveDemoUrl" target="_blank" rel="noopener noreferrer">@LiveProjectLabel ↗</a> }
                        @if (HasSourceLink) { <a class="button button-secondary" href="@Project.GitHubUrl" target="_blank" rel="noopener noreferrer">View Source</a> }
                    </div>
                }
            </div>
        </section>
    </div>
}

@code {
    [Parameter] public PortfolioProject? Project { get; set; }
    [Parameter, EditorRequired] public EventCallback OnClose { get; set; }

    private int selectedScreenshot;
    private string? loadedProjectName;
    private CancellationTokenSource? mediaCycleCancellation;
    private ElementReference videoElement;
    private bool HasLiveLink => !string.IsNullOrWhiteSpace(Project?.LiveDemoUrl) && Project.LiveDemoUrl != "#";
    private bool HasSourceLink => !string.IsNullOrWhiteSpace(Project?.GitHubUrl) && Project.GitHubUrl != "#";
    private string LiveProjectLabel => Project?.Name.Contains("Clinic", StringComparison.OrdinalIgnoreCase) == true ? "View Live Project" : "Live Project";
    private static bool IsImageScreenshot(string screenshot) => screenshot.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || screenshot.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || screenshot.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) || screenshot.EndsWith(".webp", StringComparison.OrdinalIgnoreCase);
    private static bool IsVideoPreview(string screenshot) => screenshot.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase) || screenshot.EndsWith(".webm", StringComparison.OrdinalIgnoreCase);
    private string? GetVideoPoster() => Project?.Screenshots.FirstOrDefault(IsImageScreenshot);
    private string GetScreenshotLabel(string screenshot, int index)
    {
        if (IsVideoPreview(screenshot)) return "Video preview";
        return IsImageScreenshot(screenshot) ? $"Project image {index + 1}" : screenshot;
    }

    protected override void OnParametersSet()
    {
        if (Project?.Name != loadedProjectName)
        {
            loadedProjectName = Project?.Name;
            selectedScreenshot = 0;
            StartMediaCycle();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Project?.Screenshots.Count is not > 0 || !IsVideoPreview(Project.Screenshots[selectedScreenshot])) return;
        await JS.InvokeVoidAsync("gajiWorksMedia.playMuted", videoElement);
    }

    private void SelectScreenshot(int index)
    {
        selectedScreenshot = index;
        StartMediaCycle();
    }

    private void HandleVideoEnded() => MoveToNextMedia();

    private void MoveToNextMedia()
    {
        if (Project?.Screenshots.Count is null or 0) return;
        selectedScreenshot = (selectedScreenshot + 1) % Project.Screenshots.Count;
        StartMediaCycle();
    }

    private void StartMediaCycle()
    {
        CancelMediaCycle();
        if (Project?.Screenshots.Count is null or 0 || !IsImageScreenshot(Project.Screenshots[selectedScreenshot])) return;

        mediaCycleCancellation = new CancellationTokenSource();
        _ = AdvanceImageAfterDelayAsync(selectedScreenshot, mediaCycleCancellation.Token);
    }

    private async Task AdvanceImageAfterDelayAsync(int expectedIndex, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(2500, cancellationToken);
            await InvokeAsync(() =>
            {
                if (cancellationToken.IsCancellationRequested || Project is null || selectedScreenshot != expectedIndex) return;
                MoveToNextMedia();
                StateHasChanged();
            });
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void CancelMediaCycle()
    {
        mediaCycleCancellation?.Cancel();
        mediaCycleCancellation?.Dispose();
        mediaCycleCancellation = null;
    }

    private Task Close()
    {
        CancelMediaCycle();
        selectedScreenshot = 0;
        loadedProjectName = null;
        return OnClose.InvokeAsync();
    }

    public void Dispose() => CancelMediaCycle();
}
