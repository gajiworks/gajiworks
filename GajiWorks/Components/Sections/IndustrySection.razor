@{
    var industries = new[]
    {
        ("▤", "Retail POS & Inventory"),
        ("◇", "Business Brochures & Service Showcases"),
        ("⚙", "Manufacturing & Orthopedic Footwear"),
        ("↗", "Outsourcing & Financial Systems")
    };
}

<section id="experience" class="section section-muted industry-section section-anchor">
    <div class="container">
        <div class="experience-industries-heading reveal">
            <span class="eyebrow">Industry Background</span>
            <h3>Experience that understands real operations.</h3>
            <p>Backed by work across retail, manufacturing, outsourcing, financial, and service-based environments.</p>
        </div>

        <div class="industry-grid industry-grid-compact reveal">
            @foreach (var industry in industries)
            {
                <article class="industry-card"><span>@industry.Item1</span><h3>@industry.Item2</h3></article>
            }
        </div>

        <div class="about-grid experience-intro">
            <div class="about-visual reveal">
                <div class="experience-panel"><span>10+</span><strong>Years of practical<br />industry experience</strong></div>
                <div class="about-lines"><i></i><i></i><i></i></div>
            </div>

            <div class="about-copy reveal reveal-delay">
                <SectionHeading Eyebrow="Experience" Title="Independent expertise, focused on your business." Centered="false" />
                <p class="lead-copy">This website service provider helps businesses build professional websites, catalogs, and simple business systems that improve online presence, showcase services, and support daily operations.</p>
                <p>Direct communication and practical recommendations are backed by more than a decade of experience across different industries.</p>
                <div class="value-list">
                    <div><span>✓</span><p><strong>Direct collaboration</strong><small>You work with the person building your solution.</small></p></div>
                    <div><span>✓</span><p><strong>Business-first thinking</strong><small>Every decision supports a clear practical goal.</small></p></div>
                    <div><span>✓</span><p><strong>Reliable handover</strong><small>Clear review, turnover, and support options.</small></p></div>
                </div>
            </div>
        </div>
    </div>
</section>
